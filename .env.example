# Copy to `.env` and adjust. Loaded automatically by `jupyter_base.config.load_settings`.

# Human-readable name surfaced in examples and logs
JUPYTER_BASE_APP_NAME=jupyter-base

# development | staging | production
JUPYTER_BASE_ENV=development

# Set to true/1/yes to mark debug mode in examples
JUPYTER_BASE_DEBUG=false

# Writable data directory (created by your workflows as needed)
JUPYTER_BASE_DATA_DIR=./data

# Docker Compose only: JupyterLab token (empty = no token; fine on localhost only)
# JUPYTER_LAB_TOKEN=

# Optional: host port when using docker compose (defaults to 8888)
# JUPYTER_PORT=8888
